{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Hub",
  "version": "0.1.0",
  "identifier": "com.angozero.projecthub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Project Hub",
        "width": 1480,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local hub for development projects",
    "longDescription": "Project Hub scans local roots, keeps project metadata in JSON, and launches terminal and CLI tools from the correct project directory."
  }
}
